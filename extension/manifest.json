{
  "manifest_version": 3,
  "name": "SocialMedia-Hub",
  "version": "0.1.0",
  "description": "Social media analytics sidebar - Analyze TikTok, Douyin, Instagram, YouTube, and more",
  "permissions": [
    "activeTab",
    "sidePanel",
    "storage"
  ],
  "host_permissions": [
    "https://*.tiktok.com/*",
    "https://*.douyin.com/*",
    "https://*.instagram.com/*",
    "https://*.youtube.com/*",
    "https://*.twitter.com/*",
    "https://*.x.com/*",
    "https://*.bilibili.com/*",
    "https://*.xiaohongshu.com/*",
    "https://*.weibo.com/*",
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.tiktok.com/*",
        "https://*.douyin.com/*",
        "https://*.instagram.com/*",
        "https://*.youtube.com/*",
        "https://*.twitter.com/*",
        "https://*.x.com/*",
        "https://*.bilibili.com/*",
        "https://*.xiaohongshu.com/*"
      ],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "sidepanel/sidepanel.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
